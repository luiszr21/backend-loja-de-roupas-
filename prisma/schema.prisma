generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now())
}

model Usuario {
  id        String     @id @default(uuid())
  nome      String
  email     String     @unique
  senha     String
  isAdmin   Boolean    @default(false)
  criadoEm  DateTime   @default(now())

  enderecos Endereco[]
  propostas Proposta[]
}

model Endereco {
  id        String   @id @default(uuid())
  usuarioId String
  rua       String
  numero    String
  cidade    String
  estado    String
  cep       String
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model Categoria {
  id       String    @id @default(uuid())
  nome     String    @unique
  produtos Produto[]
}

model Produto {
  id          String    @id @default(uuid())
  categoriaId String?
  nome        String
  descricao   String?
  preco       Float
  estoque     Int
  tamanho     String
  imagemUrl   String?
  destaque    Boolean   @default(false)
  criadoEm    DateTime  @default(now())
  excluidoEm  DateTime?

  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  propostas   Proposta[]

  @@index([categoriaId])
}

model Proposta {
  id            String   @id @default(uuid())
  usuarioId     String
  produtoId     String
  mensagem      String
  resposta      String?
  status        PropostaStatus @default(PENDENTE)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  produto       Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([produtoId])
}

enum PropostaStatus {
  PENDENTE
  RESPONDIDA
  ACEITA
  REJEITADA
  CANCELADA
}

model TokenRevogado {
  id         String   @id @default(uuid())
  jti        String   @unique
  usuarioId  String
  role       String
  expiracao  DateTime
  revogadoEm DateTime @default(now())

  @@index([usuarioId])
  @@index([expiracao])
}